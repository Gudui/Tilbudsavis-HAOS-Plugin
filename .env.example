# Copy this file to .env for Docker Compose local testing.
# Default settings stay fully offline by using the bundled mock provider fixtures.

OFFER_RADAR_PROVIDERS=mock
# Legacy single-provider fallback remains supported, but new setups should use OFFER_RADAR_PROVIDERS.
OFFER_RADAR_PROVIDER=

# Copenhagen defaults. Change to your own coordinates for more realistic local live tests.
OFFER_RADAR_LATITUDE=55.6761
OFFER_RADAR_LONGITUDE=12.5683
OFFER_RADAR_RADIUS_METERS=25000
OFFER_RADAR_LOCALE=da_DK

# 0 disables background sync during local development; use the manual Sync button instead.
OFFER_RADAR_SYNC_INTERVAL_MINUTES=0
OFFER_RADAR_MAX_RESULTS_PER_QUERY=24
OFFER_RADAR_PROVIDER_TIMEOUT_SECONDS=15
OFFER_RADAR_PROVIDER_RATE_LIMIT_SECONDS=2
OFFER_RADAR_PROVIDER_MAX_RETRIES=2
OFFER_RADAR_PROVIDER_USER_AGENT=OfferRadar/0.2 (+https://github.com/Gudui/Tilbudsavis-HAOS-Plugin; personal-use local add-on)
OFFER_RADAR_LIVE_PROVIDER_TESTS=false
OFFER_RADAR_CLEAR_SEED_DATA=0
OFFER_RADAR_PORT=8099

# eTilbudsavis/Tjek-style provider settings.
ETILBUDSAVIS_BASE_URL=https://api.etilbudsavis.dk
ETILBUDSAVIS_SEARCH_URL=
ETILBUDSAVIS_LOCALE=da_DK
ETILBUDSAVIS_RADIUS_METERS=10000
ETILBUDSAVIS_MAX_RESULTS_PER_QUERY=24

# MineTilbud provider settings.
MINETILBUD_BASE_URL=https://minetilbud.dk
MINETILBUD_MAX_CATALOGS_PER_SYNC=50
MINETILBUD_STORE_FILTERS=
