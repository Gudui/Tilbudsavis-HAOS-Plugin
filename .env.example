# Copy this file to .env for Docker Compose local testing.

# Use mock for deterministic local testing. Use etilbudsavis for live prototype tests.
OFFER_RADAR_PROVIDER=mock

# Copenhagen defaults. Change to your own coordinates for realistic live results.
OFFER_RADAR_LATITUDE=55.6761
OFFER_RADAR_LONGITUDE=12.5683
OFFER_RADAR_RADIUS_METERS=25000
OFFER_RADAR_LOCALE=da_DK

# 0 disables background sync during local development; use the manual Sync button instead.
OFFER_RADAR_SYNC_INTERVAL_MINUTES=0
OFFER_RADAR_MAX_RESULTS_PER_QUERY=24
OFFER_RADAR_REQUEST_TIMEOUT_SECONDS=12
OFFER_RADAR_ETILBUDSAVIS_SEARCH_URL=
OFFER_RADAR_CLEAR_SEED_DATA=0
OFFER_RADAR_PORT=8099
